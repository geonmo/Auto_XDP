#!/bin/bash
set -euo pipefail

CONFIG_FILE="/etc/auto_xdp/auto_xdp.env"
TOML_CONFIG="/etc/auto_xdp/config.toml"
RUN_STATE_DIR="/run/auto_xdp"
BPF_PIN_DIR="/sys/fs/bpf/xdp_fw"
INSTALL_DIR="/usr/local/lib/auto_xdp"
PYTHON_LIB_DIR="${INSTALL_DIR}/python"
NFT_FAMILY="inet"
NFT_TABLE="auto_xdp"
NFT_CHAIN="input"
RUNNER_SCRIPT="/usr/local/bin/auto_xdp_start.sh"
SERVICE_NAME="xdp-port-sync"
RELAY_SERVICE_NAME="auto-xdp-relay"
SYSTEMD_RUN_DIR="${SYSTEMD_RUN_DIR:-/run/systemd/system}"
RAW_URL="https://raw.githubusercontent.com/Kookiejarz/auto_xdp/main"

PORTS_WATCH=0
PORTS_INTERVAL=2
IFACE=""
BACKEND=""

usage() {
    cat <<'EOF'
Usage: axdp [command] [options]

Commands:
  stats [args...]        Show Auto XDP statistics
  tui [args...]          Open htop-like live TUI
  watch [args...]        Shorthand for: stats --watch
  ports [args...]        Show currently allowed TCP/UDP ports
  backend                Show active backend and runtime attachment state
  conntrack [args...]    Show TCP/UDP conntrack visibility
  sync [args...]         Run one sync pass with automatic backend selection
  check-update [args...] Compare installed files against GitHub and update
  log-level [LVL]        Show or change daemon log level
  under-attack [on|off] Show or change under-attack mode
  start                  Start the installed service
  stop                   Stop the installed service
  restart                Restart the installed service
  status                 Show service status
  config show            Show current TOML config
  config init            Create default config.toml (if missing)
  trust list             List trusted source IPs/CIDRs
  trust add CIDR [LABEL] Add a trusted source CIDR
  trust del CIDR         Remove a trusted source CIDR
  acl list               List per-CIDR port ACL rules
  acl add PROTO CIDR PORT...  Add an ACL rule (proto: tcp|udp)
  acl del PROTO CIDR     Remove an ACL rule
  permanent list         List permanently whitelisted ports
  permanent add PROTO PORT [LABEL]  Add a permanent port (tcp|udp|sctp)
  permanent del PROTO PORT          Remove a permanent port
  slot list              List loaded and available protocol slot handlers
  slot load NAME         Load built-in handler: gre, esp, sctp
  slot load PROTO PATH   Load custom handler .o or compile/load .c for IP proto number
  slot unload PROTO      Remove handler from slot
  help                   Show this help

Stats options:
  --watch              Refresh continuously
  --rates              Show packet/bit rate deltas
  --interval SEC       Refresh / delta interval in seconds (default: 1)
  --interface IFACE    Override interface autodetection

TUI options:
  --interval SEC       Refresh maps/ports/stats interval (default: 2)
  --socket PATH        pkt_relay Unix socket path
  --interface IFACE    Override interface autodetection

Ports options:
  --watch              Refresh continuously and detect changes
  --interval SEC       Refresh interval in seconds (default: 2)

Conntrack options:
  tcp|udp|all         Select conntrack map view (default: all)
  --limit N           Show top N destination ports per map (default: 10)

Check-update options:
  --force              Apply all updates without prompting

With no command, axdp runs: stats
EOF
}

run_service_cmd() {
    local action="$1"

    if command -v systemctl >/dev/null 2>&1 && [[ -d "$SYSTEMD_RUN_DIR" ]]; then
        systemctl "$action" "$SERVICE_NAME"
        if systemctl list-unit-files "${RELAY_SERVICE_NAME}.service" >/dev/null 2>&1; then
            systemctl "$action" "$RELAY_SERVICE_NAME" || true
        else
            echo "Relay service not installed yet. Re-run setup_xdp.sh --force to install ${RELAY_SERVICE_NAME}." >&2
        fi
        return 0
    fi

    if command -v rc-service >/dev/null 2>&1; then
        rc-service "$SERVICE_NAME" "$action"
        rc-service "$RELAY_SERVICE_NAME" "$action" 2>/dev/null || \
            echo "Relay service not installed yet. Re-run setup_xdp.sh --force to install ${RELAY_SERVICE_NAME}." >&2
        return 0
    fi

    echo "No supported init system detected for service control." >&2
    exit 1
}

ensure_installed() {
    local path="$1"
    [[ -x "$path" ]] || {
        echo "Missing executable: $path" >&2
        exit 1
    }
}


load_config() {
    local cli_iface="$IFACE"
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck disable=SC1091
        source "$CONFIG_FILE"
    fi
    if [[ -n "$cli_iface" ]]; then
        IFACE="$cli_iface"
    fi
}

# Drop CWD from sys.path before delegating to a module so an `auto_xdp/`
# directory in the caller's working directory cannot shadow the installed package.
PY_BOOTSTRAP='import sys, runpy; sys.path[:] = [p for p in sys.path if p]; runpy.run_module(sys.argv.pop(1), run_name="__main__", alter_sys=True)'

run_py_module() {
    local module="$1"
    shift
    PYTHONPATH="${PYTHON_LIB_DIR}" python3 -c "$PY_BOOTSTRAP" "$module" "$@"
}

run_admin_config() {
    run_py_module auto_xdp.admin_cli \
        --config "$TOML_CONFIG" \
        --bpf-pin-dir "$BPF_PIN_DIR" \
        --install-dir "$INSTALL_DIR" \
        "$@"
}

run_admin_runtime() {
    run_py_module auto_xdp.admin.main \
        --env-config "$CONFIG_FILE" \
        --bpf-pin-dir "$BPF_PIN_DIR" \
        --run-state-dir "$RUN_STATE_DIR" \
        --nft-family "$NFT_FAMILY" \
        --nft-table "$NFT_TABLE" \
        "$@"
}

run_log_level() {
    local level="${1:-}"

    if [[ -z "$level" ]]; then
        run_admin_config log-level
        return $?
    fi

    [[ -f "$TOML_CONFIG" ]] || run_config init
    run_admin_config log-level "$level"
    reload_daemon
    return 0
}

run_under_attack() {
    local mode="${1:-}"

    if [[ -z "$mode" ]]; then
        run_admin_config under-attack
        return $?
    fi

    [[ -f "$TOML_CONFIG" ]] || run_config init
    run_admin_config under-attack "$mode"
    reload_daemon
    return 0
}

autodetect_iface() {
    if [[ -n "$IFACE" ]]; then
        return 0
    fi

    IFACE="${IFACE:-}"
    if [[ -z "$IFACE" ]]; then
        IFACE=$(ip route show default 2>/dev/null | awk '/default/ {print $5; exit}')
    fi

    [[ -n "$IFACE" ]] || {
        echo "Could not detect interface. Use --interface IFACE." >&2
        exit 1
    }
}

_any_iface_has_xdp() {
    local _iface
    for _iface in ${IFACES:-${IFACE:-}}; do
        ip -d link show dev "$_iface" 2>/dev/null | grep -Eq 'xdp|xdpgeneric|xdpoffload' && return 0
    done
    return 1
}

detect_backend() {
    local candidate=""

    if [[ -f "${RUN_STATE_DIR}/backend" ]]; then
        candidate=$(<"${RUN_STATE_DIR}/backend")
    fi

    case "$candidate" in
        xdp)
            if [[ -e "${BPF_PIN_DIR}/pkt_counters" ]] || _any_iface_has_xdp; then
                BACKEND="xdp"
                return 0
            fi
            ;;
        nftables)
            if command -v nft &>/dev/null && nft list table "$NFT_FAMILY" "$NFT_TABLE" >/dev/null 2>&1; then
                BACKEND="nftables"
                return 0
            fi
            ;;
    esac

    if [[ -e "${BPF_PIN_DIR}/pkt_counters" ]] && _any_iface_has_xdp; then
        BACKEND="xdp"
        return 0
    fi

    if command -v nft &>/dev/null && nft list table "$NFT_FAMILY" "$NFT_TABLE" >/dev/null 2>&1; then
        BACKEND="nftables"
        return 0
    fi

    if [[ -e "${BPF_PIN_DIR}/pkt_counters" ]]; then
        BACKEND="xdp"
        return 0
    fi

    echo "No active Auto XDP backend detected." >&2
    exit 1
}

configured_ifaces() {
    if [[ -n "${IFACES:-}" ]]; then
        printf '%s\n' "$IFACES"
        return 0
    fi
    if [[ -n "${IFACE:-}" ]]; then
        printf '%s\n' "$IFACE"
        return 0
    fi
    return 1
}

iface_xdp_state() {
    local iface="$1"
    local info=""
    info=$(ip -d link show dev "$iface" 2>/dev/null || true)
    [[ -n "$info" ]] || {
        printf 'missing'
        return 0
    }
    if grep -q 'xdpgeneric' <<<"$info"; then
        printf 'generic'
        return 0
    fi
    if grep -Eq 'xdp|xdpoffload' <<<"$info"; then
        printf 'native'
        return 0
    fi
    printf 'off'
}

iface_tc_egress_state() {
    local iface="$1"
    command -v tc >/dev/null 2>&1 || {
        printf 'unavailable'
        return 0
    }
    if tc filter show dev "$iface" egress pref 49152 2>/dev/null | grep -q .; then
        printf 'attached'
        return 0
    fi
    printf 'off'
}

conntrack_entry_count() {
    local map_path="$1"
    if [[ ! -e "$map_path" ]] || ! command -v bpftool >/dev/null 2>&1; then
        printf '0'
        return 0
    fi
    { bpftool -j map dump pinned "$map_path" 2>/dev/null || printf '[]\n'; } | python3 -c '
import json, sys
try:
    rows = json.load(sys.stdin)
except Exception:
    rows = []
print(len(rows) if isinstance(rows, list) else 0)
'
}

summarize_conntrack_map() {
    local map_path="$1"
    local limit="${2:-10}"
    local script
    if [[ ! -e "$map_path" ]] || ! command -v bpftool >/dev/null 2>&1; then
        echo "TOTAL|0"
        return 0
    fi
    script=$(cat <<'PY'
import json
import sys

limit = int(sys.argv[1])

try:
    rows = json.load(sys.stdin)
except Exception:
    rows = []

if not isinstance(rows, list):
    rows = []

stats = {}

for row in rows:
    key = row.get("key", [])
    if not isinstance(key, list) or len(key) < 8:
        continue
    try:
        family = int(key[0], 0) if isinstance(key[0], str) else int(key[0])
        dport = ((int(key[6], 0) if isinstance(key[6], str) else int(key[6])) << 8) | (
            int(key[7], 0) if isinstance(key[7], str) else int(key[7])
        )
    except Exception:
        continue
    entry = stats.setdefault(dport, {"total": 0, "v4": 0, "v6": 0})
    entry["total"] += 1
    if family == 2:
        entry["v4"] += 1
    elif family == 10:
        entry["v6"] += 1

print(f"TOTAL|{len(rows)}")
for dport, entry in sorted(stats.items(), key=lambda item: (-item[1]["total"], item[0]))[:limit]:
    print(f"PORT|{dport}|{entry['total']}|{entry['v4']}|{entry['v6']}")
PY
)
    { bpftool -j map dump pinned "$map_path" 2>/dev/null || printf '[]\n'; } | python3 -c "$script" "$limit"
}

render_conntrack_summary() {
    local label="$1"
    local map_path="$2"
    local limit="${3:-10}"
    local line total=0 dport count v4 v6

    printf '%s conntrack:\n' "$label"
    while IFS='|' read -r kind a b c d; do
        case "$kind" in
            TOTAL)
                total="$a"
                ;;
            PORT)
                dport="$a"
                count="$b"
                v4="$c"
                v6="$d"
                printf '  dport %-5s total=%-4s ipv4=%-4s ipv6=%s\n' "$dport" "$count" "$v4" "$v6"
                ;;
        esac
    done < <(summarize_conntrack_map "$map_path" "$limit")

    if [[ "$total" == "0" ]]; then
        printf '  (none)\n'
    fi
    printf '  total=%s\n' "$total"
}

run_backend() {
    run_admin_runtime backend "$@"
}

run_conntrack() {
    run_admin_config conntrack "$@"
}



run_ports() {
    local args=()
    for arg in "$@"; do
        [[ "$arg" == "watch" ]] && arg="--watch"
        args+=("$arg")
    done
    run_py_module auto_xdp.admin_cli \
        --config "$TOML_CONFIG" \
        --bpf-pin-dir "$BPF_PIN_DIR" \
        --install-dir "$INSTALL_DIR" \
        --run-state-dir "$RUN_STATE_DIR" \
        --nft-family "$NFT_FAMILY" \
        --nft-table "$NFT_TABLE" \
        ports "${args[@]}"
}

run_stats() {
    run_py_module auto_xdp.admin_cli \
        --config "$TOML_CONFIG" \
        --bpf-pin-dir "$BPF_PIN_DIR" \
        --install-dir "$INSTALL_DIR" \
        --run-state-dir "$RUN_STATE_DIR" \
        --nft-family "$NFT_FAMILY" \
        --nft-table "$NFT_TABLE" \
        --iface "${IFACES:-${IFACE:-}}" \
        stats "$@"
}

run_tui() {
    run_py_module auto_xdp.admin_cli \
        --config "$TOML_CONFIG" \
        --bpf-pin-dir "$BPF_PIN_DIR" \
        --install-dir "$INSTALL_DIR" \
        --run-state-dir "$RUN_STATE_DIR" \
        --nft-family "$NFT_FAMILY" \
        --nft-table "$NFT_TABLE" \
        --iface "${IFACES:-${IFACE:-}}" \
        tui "$@"
}

run_check_update() {
    local force=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force|-f) force=1; shift ;;
            -h|--help)
                printf 'Usage: axdp check-update [--force]\n'
                printf '  --force   Apply all updates without prompting\n'
                exit 0
                ;;
            *)
                printf 'Unknown option: %s\n' "$1" >&2
                exit 1
                ;;
        esac
    done

    command -v curl >/dev/null 2>&1 || { printf 'curl is required for check-update\n' >&2; exit 1; }

    local setup_url="https://raw.githubusercontent.com/Kookiejarz/Auto_XDP/refs/heads/main/setup_xdp.sh"
    local tmp_setup
    tmp_setup=$(mktemp)
    trap 'rm -f "$tmp_setup"' EXIT

    printf 'Fetching setup_xdp.sh from GitHub...\n'
    if ! curl --proto '=https' --tlsv1.2 -sSfL "$setup_url" -o "$tmp_setup"; then
        printf 'Failed to fetch setup_xdp.sh\n' >&2
        exit 1
    fi

    if [[ $force -eq 1 ]]; then
        bash "$tmp_setup" --check-update --force
    else
        bash "$tmp_setup" --check-update
    fi
}


# TOML config management helpers
# Reload the running daemon via SIGHUP (no restart gap), or restart as fallback.
reload_daemon() {
    local pid
    if pid=$(systemctl show -p MainPID --value "$SERVICE_NAME" 2>/dev/null) && [[ "$pid" -gt 1 ]]; then
        kill -HUP "$pid" 2>/dev/null && return 0
    fi
    if command -v rc-service >/dev/null 2>&1; then
        rc-service "$SERVICE_NAME" restart 2>/dev/null && return 0
    fi
    command -v systemctl >/dev/null 2>&1 && systemctl restart "$SERVICE_NAME" 2>/dev/null || true
}

run_config() {
    local sub="${1:-show}"
    shift || true
    case "$sub" in
        show)
            run_admin_config config show "$@"
            ;;
        init)
            run_admin_config config init "$@"
            ;;
        -h|--help)
            echo "Usage: axdp config show|init"
            ;;
        *)
            echo "Unknown config subcommand: $sub" >&2; exit 1 ;;
    esac
}

run_trust() {
    local sub="${1:-list}"
    shift || true
    case "$sub" in
        list)
            run_admin_config trust list
            ;;
        add)
            [[ -f "$TOML_CONFIG" ]] || run_config init
            run_admin_config trust add "$@"
            reload_daemon
            ;;
        del)
            run_admin_config trust del "$@"
            reload_daemon
            ;;
        -h|--help)
            echo "Usage: axdp trust list|add CIDR [LABEL]|del CIDR"
            ;;
        *)
            echo "Unknown trust subcommand: $sub" >&2; exit 1 ;;
    esac
}

run_acl() {
    local sub="${1:-list}"
    shift || true
    case "$sub" in
        list)
            run_admin_config acl list
            ;;
        add)
            [[ -f "$TOML_CONFIG" ]] || run_config init
            run_admin_config acl add "$@"
            reload_daemon
            ;;
        del)
            run_admin_config acl del "$@"
            reload_daemon
            ;;
        -h|--help)
            echo "Usage: axdp acl list|add PROTO CIDR PORT...|del PROTO CIDR"
            ;;
        *)
            echo "Unknown acl subcommand: $sub" >&2; exit 1 ;;
    esac
}

run_permanent() {
    local sub="${1:-list}"
    shift || true
    case "$sub" in
        list)
            run_admin_config permanent list
            ;;
        add)
            [[ -f "$TOML_CONFIG" ]] || run_config init
            run_admin_config permanent add "$@"
            reload_daemon
            ;;
        del)
            run_admin_config permanent del "$@"
            reload_daemon
            ;;
        -h|--help)
            echo "Usage: axdp permanent list|add tcp|udp|sctp PORT [LABEL]|del tcp|udp|sctp PORT"
            ;;
        *)
            echo "Unknown permanent subcommand: $sub" >&2; exit 1 ;;
    esac
}

run_slot() {
    local sub="${1:-list}"
    shift || true

    case "$sub" in
        list|load|unload)
            run_admin_config slot "$sub" "$@"
            ;;
        *)
            echo "Usage: axdp slot list|load NAME|PROTO [PATH]|unload NAME|PROTO" >&2
            exit 1
            ;;
    esac
}

main() {
    local cmd="${1:-stats}"

    case "$cmd" in
        stats)
            shift || true
            run_stats "$@"
            ;;
        tui)
            shift || true
            run_tui "$@"
            ;;
        watch)
            shift || true
            run_stats --watch "$@"
            ;;
        ports)
            shift || true
            run_ports "$@"
            ;;
        backend)
            shift || true
            run_backend "$@"
            ;;
        conntrack)
            shift || true
            run_conntrack "$@"
            ;;
        sync)
            shift || true
            ensure_installed "$RUNNER_SCRIPT"
            exec "$RUNNER_SCRIPT" --sync-once "$@"
            ;;
        check-update)
            shift || true
            run_check_update "$@"
            ;;
        log-level)
            shift || true
            run_log_level "$@"
            ;;
        under-attack)
            shift || true
            run_under_attack "$@"
            ;;
        config)
            shift || true
            run_config "$@"
            ;;
        trust)
            shift || true
            run_trust "$@"
            ;;
        acl)
            shift || true
            run_acl "$@"
            ;;
        permanent)
            shift || true
            run_permanent "$@"
            ;;
        slot)
            shift || true
            run_slot "$@"
            ;;
        start|stop|restart|status)
            shift || true
            run_service_cmd "$cmd"
            ;;
        help|-h|--help)
            usage
            ;;
        *)
            run_stats "$@"
            ;;
    esac
}

if [[ "${BASH_SOURCE[0]:-}" == "$0" ]]; then
    main "$@"
fi
